# HomeServ Configuration
# Copy this to .env and customize

# Web UI port (default 3001)
HOMESERV_PORT=3001

# VNC WebSocket proxy port (default 3002)
VNC_WS_PORT=3002

# JWT secret for session tokens — CHANGE THIS!
JWT_SECRET=replace-with-a-random-64-char-string

# VNC server on the host machine
VNC_HOST=host.docker.internal
VNC_PORT=5900
